@startuml modelo_dominio
title Modelo de Domínio - Hotel de Animais

skinparam style strictuml
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 140
skinparam ranksep 170
skinparam padding 2
skinparam ArrowThickness 1
skinparam ArrowFontSize 9
skinparam ClassFontSize 12
skinparam ClassAttributeFontSize 11

left to right direction

class Tutor {
  nome
  nif
  contacto
  email
}

class Animal {
  nome
  especie
  raca
  dataNascimento
  peso
  estadoSaude
  cuidadosRecorrentes
}

class TipoAlojamentoTarifa {
  tipoAlojamento
  tarifaDiaria
  ativo
}

class Alojamento {
  identificacao
  tipo
  capacidade
  estadoLimpeza
}

class Reserva {
  dataInicio
  dataFim
  estado
  instrucoes
}

class Estadia {
  dataCheckIn
  dataCheckOut
  estado
}

class PlanoCuidados {
  instrucoes
  prioridade
  ativo
}

class TarefaCuidado {
  descricao
  periodicidade
  concluida
}

class RegistoCuidado {
  tipo
  observacoes
  dataHora
}

class Nota {
  texto
  dataHora
}

class TipoServicoExtra {
  nome
  descricao
  ativo
}

class ServicoExtra {
  descricao
  custo
  dataHora
}

class IntervencaoClinica {
  descricao
  prescricao
  custo
  dataHora
}

class AlteracaoEstadoSaude {
  descricao
  severidade
  dataHora
}

class Pagamento {
  valor
  metodo
  momento
  estado
  dataHora
}

class Colaborador {
  nome
  email
  perfil
}

class AuditoriaEvento {
  timestamp
  operacao
  entidade
  resultado
}

enum Especie {
  CAO
  GATO
}

enum EstadoSaude {
  NORMAL
  ALTERADO
  CRITICO
}

enum EstadoLimpeza {
  PENDENTE
  CONCLUIDO
}

enum EstadoReserva {
  ATIVA
  CONFIRMADA
  CANCELADA
  CONCLUIDA
}

enum EstadoEstadia {
  EM_CURSO
  TERMINADA
}

enum EstadoPagamento {
  LIQUIDADO
  PENDENTE
}

enum MomentoPagamento {
  CHECK_IN
  CHECK_OUT
}

enum MetodoPagamento {
  NUMERARIO
  CARTAO_DEBITO
  CARTAO_CREDITO
}

enum PrioridadePlano {
  ROTINA
  URGENTE
  CRITICO
}

enum PeriodicidadeTarefa {
  UNICA
  DIARIA
  SEMANAL
}

enum TipoColaborador {
  DIRETOR
  FUNCIONARIO_RECEPCAO
  CUIDADOR
  MEDICO_VETERINARIO
  RESPONSAVEL_LIMPEZA
}

enum ResultadoAuditoria {
  SUCESSO
  FALHA
}

Tutor "1" -down- "0..*" Animal : > responsavel
Tutor "1" -right- "0..*" Reserva : > solicita
Animal "1" -right- "0..*" Reserva : > tem
TipoAlojamentoTarifa "1" -down- "0..*" Alojamento : > classifica
Alojamento "1" -right- "0..*" Reserva : > reservado

Reserva "1" -right- "0..1" Estadia : > origina
Reserva "1" -down- "0..*" Nota : > contem

Animal "1" -down- "0..*" PlanoCuidados : > mantem
Estadia "1" -down- "1" PlanoCuidados : > ativa
PlanoCuidados "1" -right- "0..*" TarefaCuidado : > organiza
Estadia "1" -down- "0..*" RegistoCuidado : > regista
Estadia "1" -right- "0..*" ServicoExtra : > inclui
Estadia "1" -right- "0..*" IntervencaoClinica : > inclui
Estadia "1" -right- "0..*" AlteracaoEstadoSaude : > regista
Estadia "1" -down- "0..*" Pagamento : > gera

TipoServicoExtra "1" -down- "0..*" ServicoExtra : > tipifica

Colaborador "1" -up- "0..*" Nota : > escreve
Colaborador "1" -left- "0..*" RegistoCuidado : > regista
Colaborador "1" -left- "0..*" ServicoExtra : > regista
Colaborador "1" -left- "0..*" IntervencaoClinica : > regista
Colaborador "1" -left- "0..*" AlteracaoEstadoSaude : > regista
Colaborador "1" -down- "0..*" AuditoriaEvento : > origina

Animal "1" -down- "1" Especie : > usa
Animal "1" -down- "1" EstadoSaude : > usa
Alojamento "1" -down- "1" EstadoLimpeza : > usa
Reserva "1" -down- "1" EstadoReserva : > usa
Estadia "1" -down- "1" EstadoEstadia : > usa
PlanoCuidados "1" -down- "1" PrioridadePlano : > usa
TarefaCuidado "1" -down- "1" PeriodicidadeTarefa : > usa
Pagamento "1" -down- "1" EstadoPagamento : > usa
Pagamento "1" -down- "1" MomentoPagamento : > usa
Pagamento "1" -down- "1" MetodoPagamento : > usa
Colaborador "1" -down- "1" TipoColaborador : > usa
AuditoriaEvento "1" -down- "1" ResultadoAuditoria : > usa

note right of Alojamento
Um alojamento só fica disponível
se não tiver reserva sobreposta,
não tiver estadia ativa, estiver limpo
e for compatível com o animal.
end note

note bottom of Pagamento
O pagamento de CHECK_IN cobre
o valor base da estadia.
O pagamento de CHECK_OUT cobre
valores complementares.
end note

note bottom of AuditoriaEvento
Regista operações críticas:
reservas, check-in, check-out,
pagamentos, limpeza, serviços,
intervenções e gestão de perfis.
end note

@enduml
