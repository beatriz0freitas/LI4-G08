    EC --> ES
    PC --> PS
    SEC --> SES
    CC --> CLS
    CC --> ANS
    LC --> LS
    RLC --> RLS
    COC --> CS

    %% Ligações Service → Repository (principais)
    CS --> CR
    ALS --> ALR
    TS --> TR
    ANS --> ANR
    RS --> RR
    RS --> ALR
    ES --> ER
    ES --> RR
