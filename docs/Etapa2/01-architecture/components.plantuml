@startuml
title Sistema Patas & Bigodes - Diagrama de Componentes

skinparam style strictuml
skinparam componentStyle uml2
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho
skinparam backgroundColor white
skinparam defaultFontName Arial
skinparam nodesep 95
skinparam ranksep 110

left to right direction

actor "Utilizador" as Utilizador

() "IColaboradorService" as IColaboradorService
() "IDashboardService" as IDashboardService
() "IAlojamentoService" as IAlojamentoService
() "ITutorService" as ITutorService
() "IAnimalService" as IAnimalService
() "IReservaService" as IReservaService
() "IEstadiaService" as IEstadiaService
() "IPagamentoService" as IPagamentoService
() "IRegistoCuidadoService" as IRegistoCuidadoService
() "IPlanoCuidadosService" as IPlanoCuidadosService
() "INotaService" as INotaService
() "IServicoExtraService" as IServicoExtraService
() "IClinicaService" as IClinicaService
() "IIntervencaoClinicaService" as IIntervencaoClinicaService
() "IAlteracaoEstadoSaudeService" as IAlteracaoEstadoSaudeService
() "ILimpezaService" as ILimpezaService
() "IHistoricoService" as IHistoricoService
() "IRelatorioService" as IRelatorioService
() "IRegraDominioService" as IRegraDominioService
() "IAvailabilityDomainService" as IAvailabilityDomainService
() "IAuditoriaService" as IAuditoriaService

package "pt.hotel.animais.controller" as ControllerPkg {
  component "AuthController" as AuthController
  component "DashboardController" as DashboardController
  component "AlojamentoController" as AlojamentoController
  component "TutorAnimalController" as TutorAnimalController
  component "AnimalController" as AnimalController
  component "ReservaController" as ReservaController
  component "EstadiaController" as EstadiaController
  component "PagamentoController" as PagamentoController
  component "RegistoCuidadoController" as RegistoCuidadoController
  component "PlanoCuidadosController" as PlanoCuidadosController
  component "NotaController" as NotaController
  component "ServicoExtraController" as ServicoExtraController
  component "ClinicaController" as ClinicaController
  component "LimpezaController" as LimpezaController
  component "HistoricoController" as HistoricoController
  component "RelatorioController" as RelatorioController
  component "ColaboradorController" as ColaboradorController
  component "TipoAlojamentoTarifaController" as TipoAlojamentoTarifaController
  component "TipoServicoExtraController" as TipoServicoExtraController
  component "AuditoriaController" as AuditoriaController
}

package "pt.hotel.animais.service" as ServicePkg {
  component "ColaboradorService" as ColaboradorService
  component "DashboardService" as DashboardService
  component "AlojamentoService" as AlojamentoService
  component "TutorService" as TutorService
  component "AnimalService" as AnimalService
  component "ReservaService" as ReservaService
  component "EstadiaService" as EstadiaService
  component "PagamentoService" as PagamentoService
  component "RegistoCuidadoService" as RegistoCuidadoService
  component "PlanoCuidadosService" as PlanoCuidadosService
  component "NotaService" as NotaService
  component "ServicoExtraService" as ServicoExtraService
  component "ClinicaService" as ClinicaService
  component "IntervencaoClinicaService" as IntervencaoClinicaService
  component "AlteracaoEstadoSaudeService" as AlteracaoEstadoSaudeService
  component "LimpezaService" as LimpezaService
  component "HistoricoService" as HistoricoService
  component "RelatorioService" as RelatorioService
  component "TipoAlojamentoTarifaService" as TipoAlojamentoTarifaService
  component "TipoServicoExtraService" as TipoServicoExtraService
  component "RegraDominioService" as RegraDominioService
  component "AvailabilityDomainService" as AvailabilityDomainService
}

package "pt.hotel.animais.service.auditoria" as AuditoriaServicePkg {
  component "AuditoriaService" as AuditoriaService
  component "AuditoriaOperacaoService" as AuditoriaOperacaoService
}

package "pt.hotel.animais.repository" as RepositoryPkg {
  component "ColaboradorRepository" as ColaboradorRepository
  component "AlojamentoRepository" as AlojamentoRepository
  component "TutorRepository" as TutorRepository
  component "AnimalRepository" as AnimalRepository
  component "ReservaRepository" as ReservaRepository
  component "EstadiaRepository" as EstadiaRepository
  component "PagamentoRepository" as PagamentoRepository
  component "RegistoCuidadoRepository" as RegistoCuidadoRepository
  component "PlanoCuidadosRepository" as PlanoCuidadosRepository
  component "TarefaCuidadoRepository" as TarefaCuidadoRepository
  component "NotaRepository" as NotaRepository
  component "ServicoExtraRepository" as ServicoExtraRepository
  component "TipoServicoExtraRepository" as TipoServicoExtraRepository
  component "IntervencaoClinicaRepository" as IntervencaoClinicaRepository
  component "AlteracaoEstadoSaudeRepository" as AlteracaoEstadoSaudeRepository
  component "TipoAlojamentoTarifaRepository" as TipoAlojamentoTarifaRepository
  component "AuditoriaRepository" as AuditoriaRepository
}

database "hotelanimais" as DB

Utilizador -[hidden]right-> ControllerPkg
ControllerPkg -[hidden]right-> ServicePkg
ServicePkg -[hidden]right-> AuditoriaServicePkg
AuditoriaServicePkg -[hidden]right-> RepositoryPkg
RepositoryPkg -[hidden]right-> DB

Utilizador --> AuthController
Utilizador --> DashboardController

ColaboradorService - IColaboradorService
DashboardService - IDashboardService
AlojamentoService - IAlojamentoService
TutorService - ITutorService
AnimalService - IAnimalService
ReservaService - IReservaService
EstadiaService - IEstadiaService
PagamentoService - IPagamentoService
RegistoCuidadoService - IRegistoCuidadoService
PlanoCuidadosService - IPlanoCuidadosService
NotaService - INotaService
ServicoExtraService - IServicoExtraService
ClinicaService - IClinicaService
IntervencaoClinicaService - IIntervencaoClinicaService
AlteracaoEstadoSaudeService - IAlteracaoEstadoSaudeService
LimpezaService - ILimpezaService
HistoricoService - IHistoricoService
RelatorioService - IRelatorioService
RegraDominioService - IRegraDominioService
AvailabilityDomainService - IAvailabilityDomainService
AuditoriaService - IAuditoriaService

ControllerPkg ..> ServicePkg
ControllerPkg ..> AuditoriaServicePkg
ServicePkg ..> AuditoriaServicePkg
ServicePkg ..> RepositoryPkg
AuditoriaServicePkg ..> RepositoryPkg
RepositoryPkg --> DB

@enduml
