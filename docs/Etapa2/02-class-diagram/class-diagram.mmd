  class Colaborador {
    <<entity>>
    -Long id
    -String username
    -String nome
    -String email
    -String passwordHash
    -TipoColaborador tipoColaborador
    -boolean ativo
    -LocalDateTime dataCriacao
    -LocalDateTime ultimoLogin
  }

  class Tutor {
    <<entity>>
    -Long id
    -String nome
    -String nif
    -String contacto
    -String email
    -LocalDateTime dataRegisto
  }

  class Animal {
    <<entity>>
    -Long id
    -String nome
    -Especie especie
    -String raca
    -LocalDate dataNascimento
    -BigDecimal peso
    -EstadoSaude estadoSaude
    -String necessidadesAlimentares
    -String medicacaoCurso
    -LocalDateTime dataRegisto
  }

  class Alojamento {
    <<entity>>
    -Long id
    -String identificacao
    -String tipo
    -Integer capacidade
    -EstadoLimpeza estadoLimpeza
  }

  class Reserva {
    <<entity>>
    -Long id
    -LocalDate dataInicio
    -LocalDate dataFim
    -EstadoReserva estado
    -LocalDateTime dataCriacao
    +isAtiva() boolean
    +isConfirmada() boolean
    +podeFazerCheckIn() boolean
    +podeSerCancelada() boolean
    +temSobreposicao(inicio: LocalDate, fim: LocalDate) boolean
  }

  class Estadia {
    <<entity>>
    -Long id
    -LocalDateTime dataInicio
    -LocalDateTime dataFim
    -EstadoEstadia estado
    -LocalDateTime dataCriacao
  }

  class Pagamento {
    <<entity>>
    -Long id
    -BigDecimal valor
    -MetodoPagamento metodoPagamento
    -MomentoPagamento momentoPagamento
    -EstadoPagamento estadoPagamento
    -LocalDateTime dataCriacao
  }

  class RegistoCuidado {
    <<entity>>
    -Long id
    -String descricao
    -LocalDateTime dataHora
    -Long autorId
    -LocalDateTime createdAt
  }

  class PlanoCuidados {
    <<entity>>
    -Long id
    -LocalDateTime dataInicio
    -LocalDateTime dataFim
    -PrioridadePlano prioridade
    -Boolean ativo
    -String instrucoes
    -LocalDateTime createdAt
    -Long createdBy
    -LocalDateTime updatedAt
    -Long updatedBy
  }

  class TarefaCuidado {
    <<entity>>
    -Long id
    -String tipo
    -String descricao
    -PeriodicidadeTarefa periodicidade
    -LocalDateTime dataHora
    -Boolean concluida
    -Long autorConclusaoId
    -LocalDateTime createdAt
    -Long createdBy
  }

  class Nota {
    <<entity>>
    -Long id
    -String descricao
    -Long autorId
    -LocalDateTime dataHora
    -LocalDateTime createdAt
  }

  class ServicoExtra {
    <<entity>>
    -Long id
    -BigDecimal custo
    -LocalDateTime dataHora
    -Long autorId
    -LocalDateTime createdAt
  }

  class TipoServicoExtra {
    <<entity>>
    -Long id
    -String nome
    -String descricao
    -Boolean ativo
    -LocalDateTime dataCriacao
  }

  class IntervencaoClinica {
    <<entity>>
    -Long id
    -String descricao
    -BigDecimal custo
    -LocalDateTime dataHora
    -Long medicoId
    -LocalDateTime createdAt
  }

  class AlteracaoEstadoSaude {
    <<entity>>
    -Long id
    -String descricao
    -EstadoSaude severidade
    -LocalDateTime dataHora
    -Long autorId
    -LocalDateTime createdAt
  }

  class TipoAlojamentoTarifa {
    <<entity>>
    -Long id
    -String tipoAlojamento
    -BigDecimal tarifaDiaria
    -Boolean ativo
    -LocalDateTime dataCriacao
  }

  class AuditoriaEvento {
    <<entity>>
    -Long id
    -LocalDateTime timestamp
    -String operacao
    -String entidade
    -Long entityId
    -String acao
    -Map detalhes
    -ResultadoAuditoria resultado
    -String motivoFalha
  }

  class TipoColaborador {
    <<enumeration>>
    DIRETOR
    FUNCIONARIO_RECEPCAO
    CUIDADOR
    MEDICO_VETERINARIO
    RESPONSAVEL_LIMPEZA
  }
  class Especie {
    <<enumeration>>
    CAO
    GATO
  }
  class EstadoSaude {
    <<enumeration>>
    NORMAL
    ALTERADO
    CRITICO
  }
  class EstadoLimpeza {
    <<enumeration>>
    PENDENTE
    CONCLUIDO
  }
  class EstadoReserva {
    <<enumeration>>
    ATIVA
    CONFIRMADA
    CANCELADA
    CONCLUIDA
  }
  class EstadoEstadia {
    <<enumeration>>
    EM_CURSO
    TERMINADA
  }
  class MetodoPagamento {
    <<enumeration>>
    NUMERARIO
    CARTAO_DEBITO
    CARTAO_CREDITO
  }
  class MomentoPagamento {
    <<enumeration>>
    CHECK_IN
    CHECK_OUT
    EXTRAS
  }
  class EstadoPagamento {
    <<enumeration>>
    LIQUIDADO
    PENDENTE
  }
  class PrioridadePlano {
    <<enumeration>>
    ROTINA
    URGENTE
    CRITICO
  }
  class PeriodicidadeTarefa {
    <<enumeration>>
    UNICA
    DIARIA
    SEMANAL
  }
  class ResultadoAuditoria {
    <<enumeration>>
    SUCESSO
    FALHA
  }

