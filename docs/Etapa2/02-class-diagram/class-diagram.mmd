  TipoServicoExtraRepository ..> TipoServicoExtra
  IntervencaoClinicaRepository ..> IntervencaoClinica
  AlteracaoEstadoSaudeRepository ..> AlteracaoEstadoSaude
  TipoAlojamentoTarifaRepository ..> TipoAlojamentoTarifa
