@startuml UC-01
title UC-01 - Autenticar no Sistema

autonumber
actor Colaborador
participant AuthController
participant SpringSecurity
participant ColaboradorUserDetailsService
participant ColaboradorRepository

Colaborador -> AuthController : GET /login
AuthController --> Colaborador : formulario de login
Colaborador -> SpringSecurity : POST /login(username, password)
SpringSecurity -> ColaboradorUserDetailsService : loadUserByUsername(username)
ColaboradorUserDetailsService -> ColaboradorRepository : findByUsername(username)

alt colaborador encontrado e ativo
  ColaboradorRepository --> ColaboradorUserDetailsService : Colaborador
  ColaboradorUserDetailsService --> SpringSecurity : UserDetails com roles
  SpringSecurity -> SpringSecurity : validar password BCrypt
  alt credenciais validas
    SpringSecurity --> Colaborador : redirecionar para /
  else password invalida
    SpringSecurity --> Colaborador : redirecionar para /login?error
  end
else colaborador inexistente/inativo
  ColaboradorRepository --> ColaboradorUserDetailsService : vazio
  ColaboradorUserDetailsService --> SpringSecurity : UsernameNotFoundException
  SpringSecurity --> Colaborador : redirecionar para /login?error
end

@enduml
