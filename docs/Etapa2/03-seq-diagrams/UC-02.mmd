sequenceDiagram
    autonumber
    actor UtilizadorAutorizado
    participant ReservaController
    participant IAnimalService
    participant IAlojamentoService
    participant AlojamentoRepository

    UtilizadorAutorizado->>ReservaController: POST /reservas/procurar-disponibilidade
    ReservaController->>IAnimalService: obter(animalId)
    IAnimalService-->>ReservaController: Animal com especie
    ReservaController->>IAlojamentoService: consultarDisponibilidade(inicio, fim, especie)
    IAlojamentoService->>AlojamentoRepository: findAvailableForPeriodAndTipo(inicio, fim, tipo)
    AlojamentoRepository-->>IAlojamentoService: alojamentos limpos, compativeis e sem conflitos
    alt lista vazia
        IAlojamentoService-->>ReservaController: []
        ReservaController-->>UtilizadorAutorizado: apresentar indisponibilidade
    else alojamentos encontrados
        IAlojamentoService-->>ReservaController: DisponibilidadeAlojamentoDto[]
        ReservaController-->>UtilizadorAutorizado: apresentar alojamentos disponiveis
    end
