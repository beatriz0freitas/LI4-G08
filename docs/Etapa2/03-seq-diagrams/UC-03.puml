@startuml UC-03
title UC-03 - Registar Tutor e Animal

autonumber
actor FuncionarioRececao
participant TutorAnimalController
participant ITutorService
participant IAnimalService
participant TutorRepository
participant AnimalRepository

FuncionarioRececao -> TutorAnimalController : POST /tutores
TutorAnimalController -> ITutorService : registar(TutorFormDto)
ITutorService -> TutorRepository : findByNif(nif)

alt NIF duplicado
  TutorRepository --> ITutorService : Tutor existente
  ITutorService --> TutorAnimalController : erro de duplicacao
  TutorAnimalController --> FuncionarioRececao : mostrar erro no formulario
else NIF livre
  TutorRepository --> ITutorService : vazio
  ITutorService -> TutorRepository : save(tutor)
  TutorRepository --> ITutorService : tutor criado
  ITutorService --> TutorAnimalController : Tutor
  TutorAnimalController --> FuncionarioRececao : redirecionar para detalhe do tutor
end

FuncionarioRececao -> TutorAnimalController : POST /tutores/{tutorId}/animais
TutorAnimalController -> ITutorService : obter(tutorId)
ITutorService --> TutorAnimalController : Tutor
TutorAnimalController -> IAnimalService : registar(AnimalFormDto)
IAnimalService -> ITutorService : obter(tutorId)
ITutorService --> IAnimalService : Tutor
IAnimalService -> AnimalRepository : save(animal)
AnimalRepository --> IAnimalService : animal criado
IAnimalService --> TutorAnimalController : Animal
TutorAnimalController --> FuncionarioRececao : confirmar registo

@enduml
