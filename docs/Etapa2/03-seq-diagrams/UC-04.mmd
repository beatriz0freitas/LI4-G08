sequenceDiagram
    autonumber
    actor FuncionarioRececao
    participant ReservaController
    participant IReservaService
    participant ITutorService
    participant IAnimalService
    participant ReservaRepository
    participant AvailabilityDomainService
    participant AlojamentoRepository
    participant AuditoriaOperacaoService

    FuncionarioRececao->>ReservaController: POST /reservas
    ReservaController->>IReservaService: criar(ReservaFormDto)
    IReservaService->>ITutorService: obter(tutorId)
    ITutorService-->>IReservaService: Tutor
    IReservaService->>IAnimalService: obter(animalId)
    IAnimalService-->>IReservaService: Animal
    IReservaService->>ReservaRepository: countActiveInPeriod(alojamentoId, inicio, fim)
    alt existe conflito
        ReservaRepository-->>IReservaService: conflitos > 0
        IReservaService-->>ReservaController: erro overbooking
        ReservaController-->>FuncionarioRececao: mostrar erro
    else sem conflito inicial
        ReservaRepository-->>IReservaService: 0
        IReservaService->>AvailabilityDomainService: validarDisponivelParaReservaComLock(...)
        AvailabilityDomainService->>AlojamentoRepository: findByIdForUpdate(alojamentoId)
        AvailabilityDomainService->>AlojamentoRepository: countConflictingReservas / countEstadiasAtivas
        AvailabilityDomainService-->>IReservaService: Alojamento validado
        IReservaService->>ReservaRepository: save(reserva ATIVA)
        ReservaRepository-->>IReservaService: reserva criada
        IReservaService->>AuditoriaOperacaoService: registarSucesso(CRIAR_RESERVA)
        IReservaService-->>ReservaController: Reserva
        ReservaController-->>FuncionarioRececao: redirecionar para detalhe
    end
