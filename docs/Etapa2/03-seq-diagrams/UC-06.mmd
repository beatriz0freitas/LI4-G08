sequenceDiagram
    autonumber
    actor FuncionarioRececao
    participant EstadiaController
    participant IEstadiaService
    participant IReservaService
    participant AnimalRepository
    participant EstadiaRepository
    participant IPagamentoService
    participant TipoAlojamentoTarifaService
    participant AuditoriaOperacaoService

    FuncionarioRececao->>EstadiaController: POST /estadias/check-in
    EstadiaController->>EstadiaController: parseMetodoPagamento(metodo)
    alt metodo ausente/invalido
        EstadiaController-->>FuncionarioRececao: erro de metodo obrigatorio
    else metodo valido
        EstadiaController->>IEstadiaService: abrirEstadiaPorReserva(reservaId, metodo)
        IEstadiaService->>IReservaService: obter(reservaId)
        IReservaService-->>IEstadiaService: Reserva ATIVA
        IEstadiaService->>AnimalRepository: findByIdForUpdate(animalId)
        IEstadiaService->>EstadiaRepository: findEmCursoPorAnimal(animalId)
        alt animal ja tem estadia em curso
            EstadiaRepository-->>IEstadiaService: Estadia existente
            IEstadiaService-->>EstadiaController: EstadiaExistenteException
            EstadiaController-->>FuncionarioRececao: mostrar erro
        else sem estadia ativa
            EstadiaRepository-->>IEstadiaService: vazio
            IEstadiaService->>IReservaService: confirmar(reservaId)
            IEstadiaService->>EstadiaRepository: save(estadia EM_CURSO)
            IEstadiaService->>IPagamentoService: calcularValorBase(estadia)
            IPagamentoService->>TipoAlojamentoTarifaService: obterValorTarifa(tipo)
            TipoAlojamentoTarifaService-->>IPagamentoService: tarifa ativa
            IEstadiaService->>IPagamentoService: registrarPagamento(CHECK_IN)
            IEstadiaService->>AuditoriaOperacaoService: registarSucesso(CHECK_IN)
            IEstadiaService-->>EstadiaController: Estadia
            EstadiaController-->>FuncionarioRececao: check-in registado
        end
    end
