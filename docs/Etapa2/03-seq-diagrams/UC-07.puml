@startuml UC-07
title UC-07 - Registar Check-out

autonumber
actor FuncionarioRececao
participant EstadiaController
participant IEstadiaService
participant EstadiaRepository
participant IPagamentoService
participant ServicoExtraRepository
participant IntervencaoClinicaRepository
participant IReservaService
participant IAlojamentoService
participant AuditoriaOperacaoService

FuncionarioRececao -> EstadiaController : POST /estadias/check-out
EstadiaController -> EstadiaController : parseMetodoPagamento(metodo)

alt metodo ausente/invalido
  EstadiaController --> FuncionarioRececao : erro de metodo obrigatorio
else metodo valido
  EstadiaController -> IEstadiaService : checkOut(estadiaId, metodo)
  IEstadiaService -> EstadiaRepository : findById(estadiaId)
  alt estadia inexistente ou nao EM_CURSO
    EstadiaRepository --> IEstadiaService : vazio/estado invalido
    IEstadiaService --> EstadiaController : erro
    EstadiaController --> FuncionarioRececao : mostrar erro
  else estadia em curso
    EstadiaRepository --> IEstadiaService : Estadia
    IEstadiaService -> IPagamentoService : registrarPagamentoCheckOut(estadiaId, metodo)
    IPagamentoService -> ServicoExtraRepository : sumCustoByEstadia(estadiaId)
    IPagamentoService -> IntervencaoClinicaRepository : sumCustoByEstadia(estadiaId)
    IPagamentoService -> EstadiaRepository : findById(estadiaId)
    IPagamentoService --> IEstadiaService : pagamento complementar liquidado
    IEstadiaService -> EstadiaRepository : save(estadia TERMINADA)
    IEstadiaService -> IReservaService : concluir(reservaId)
    IEstadiaService -> IAlojamentoService : marcarPendenteLimpeza(alojamentoId)
    IEstadiaService -> AuditoriaOperacaoService : registarSucesso(CHECK_OUT)
    IEstadiaService --> EstadiaController : Estadia terminada
    EstadiaController --> FuncionarioRececao : check-out registado
  end
end

@enduml
