@startuml UC-08
title UC-08 - Processar Pagamento

autonumber
actor FuncionarioRececao
participant PagamentoController
participant IPagamentoService
participant EstadiaRepository
participant PagamentoRepository
participant AuditoriaOperacaoService

FuncionarioRececao -> PagamentoController : POST /pagamentos
PagamentoController -> IPagamentoService : registrarPagamento(PagamentoDto)

alt metodo ausente
  IPagamentoService --> PagamentoController : erro metodo obrigatorio
  PagamentoController --> FuncionarioRececao : mostrar erro
else metodo indicado
  IPagamentoService -> EstadiaRepository : findById(estadiaId)
  alt estadia inexistente
    EstadiaRepository --> IPagamentoService : vazio
    IPagamentoService --> PagamentoController : erro
    PagamentoController --> FuncionarioRececao : mostrar erro
  else estadia encontrada
    EstadiaRepository --> IPagamentoService : Estadia
    IPagamentoService -> PagamentoRepository : save(pagamento)
    PagamentoRepository --> IPagamentoService : Pagamento
    IPagamentoService -> AuditoriaOperacaoService : registarSucesso(PAGAMENTO_CRIADO)
    IPagamentoService --> PagamentoController : Pagamento
    PagamentoController --> FuncionarioRececao : confirmar pagamento
  end
end

@enduml
