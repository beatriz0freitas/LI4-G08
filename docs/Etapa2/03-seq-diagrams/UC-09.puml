@startuml UC-09
title UC-09 - Registar Cuidados e Notas Operacionais

autonumber
actor ColaboradorAutorizado
participant PlanoCuidadosController
participant RegistoCuidadoController
participant NotaController
participant ClinicaController
participant IPlanoCuidadosService
participant IRegistoCuidadoService
participant INotaService
participant IAlteracaoEstadoSaudeService
participant EstadiaRepository
participant PlanoCuidadosRepository
participant TarefaCuidadoRepository
participant RegistoCuidadoRepository
participant NotaRepository

ColaboradorAutorizado -> PlanoCuidadosController : GET /plano-cuidados?estadiaId=...
PlanoCuidadosController -> IPlanoCuidadosService : obterPlanoPorEstadia(estadiaId)
IPlanoCuidadosService -> PlanoCuidadosRepository : findByEstadiaId(estadiaId)
IPlanoCuidadosService -> TarefaCuidadoRepository : findByPlanoCuidadosId(planoId)
IPlanoCuidadosService --> PlanoCuidadosController : PlanoCuidadosDto
PlanoCuidadosController --> ColaboradorAutorizado : mostrar plano e tarefas

opt registar cuidado prestado
  ColaboradorAutorizado -> RegistoCuidadoController : POST /cuidados/create
  RegistoCuidadoController -> IRegistoCuidadoService : create(form, autorId)
  IRegistoCuidadoService -> EstadiaRepository : findById(estadiaId)
  IRegistoCuidadoService -> RegistoCuidadoRepository : save(registo)
  IRegistoCuidadoService --> RegistoCuidadoController : RegistoCuidadoDto
  RegistoCuidadoController --> ColaboradorAutorizado : confirmar registo
end

opt concluir tarefa do plano
  ColaboradorAutorizado -> PlanoCuidadosController : POST /plano-cuidados/tarefa/{id}/concluir
  PlanoCuidadosController -> IPlanoCuidadosService : marcarTarefaConcluida(tarefaId, autorId)
  IPlanoCuidadosService -> TarefaCuidadoRepository : findById(tarefaId)
  IPlanoCuidadosService -> TarefaCuidadoRepository : save(tarefa concluida)
  PlanoCuidadosController --> ColaboradorAutorizado : confirmar conclusao
end

opt adicionar nota de reserva
  ColaboradorAutorizado -> NotaController : POST /notas/create
  NotaController -> INotaService : create(form, autorId)
  INotaService -> NotaRepository : save(nota)
  INotaService --> NotaController : NotaDto
  NotaController --> ColaboradorAutorizado : confirmar nota
end

opt registar alteracao de saude
  ColaboradorAutorizado -> ClinicaController : POST /clinica/alteracoes/create
  ClinicaController -> IAlteracaoEstadoSaudeService : register(form)
  IAlteracaoEstadoSaudeService -> EstadiaRepository : findById(estadiaId)
  IAlteracaoEstadoSaudeService -> PlanoCuidadosRepository : findByEstadiaId(estadiaId)
  opt severidade CRITICO e plano existente
    IAlteracaoEstadoSaudeService -> IPlanoCuidadosService : atualizarPrioridade(CRITICO)
  end
  IAlteracaoEstadoSaudeService --> ClinicaController : AlteracaoEstadoSaudeDto
  ClinicaController --> ColaboradorAutorizado : confirmar alteracao
end

@enduml
