sequenceDiagram
    autonumber
    actor ColaboradorAutorizado
    participant ServicoExtraController
    participant IServicoExtraService
    participant EstadiaRepository
    participant TipoServicoExtraService
    participant ServicoExtraRepository
    participant AuditoriaOperacaoService

    ColaboradorAutorizado->>ServicoExtraController: POST /extras/create
    ServicoExtraController->>IServicoExtraService: register(form, autorId)
    IServicoExtraService->>EstadiaRepository: findById(estadiaId)
    alt estadia inexistente ou terminada
        EstadiaRepository-->>IServicoExtraService: vazio/estado invalido
        IServicoExtraService-->>ServicoExtraController: erro
        ServicoExtraController-->>ColaboradorAutorizado: mostrar erro
    else estadia EM_CURSO
        EstadiaRepository-->>IServicoExtraService: Estadia
        IServicoExtraService->>TipoServicoExtraService: obterPorNome(tipo)
        alt tipo inexistente/inativo ou custo invalido
            TipoServicoExtraService-->>IServicoExtraService: erro
            IServicoExtraService-->>ServicoExtraController: erro
            ServicoExtraController-->>ColaboradorAutorizado: mostrar erro
        else tipo ativo
            TipoServicoExtraService-->>IServicoExtraService: TipoServicoExtra
            IServicoExtraService->>ServicoExtraRepository: save(servicoExtra)
            IServicoExtraService->>AuditoriaOperacaoService: registarSucesso(SERVICO_EXTRA)
            IServicoExtraService-->>ServicoExtraController: ServicoExtraDto
            ServicoExtraController-->>ColaboradorAutorizado: confirmar registo
        end
    end
