@startuml UC-12
title UC-12 - Registar Limpeza de Alojamento

autonumber
actor ResponsavelLimpeza
participant LimpezaController
participant ILimpezaService
participant AlojamentoRepository
participant AuditoriaOperacaoService

ResponsavelLimpeza -> LimpezaController : GET /limpeza
LimpezaController -> ILimpezaService : listarAlojamentosPendentes()
ILimpezaService -> AlojamentoRepository : findByEstadoLimpeza(PENDENTE)
AlojamentoRepository --> ILimpezaService : alojamentos pendentes
ILimpezaService --> LimpezaController : lista
LimpezaController --> ResponsavelLimpeza : mostrar pendentes

ResponsavelLimpeza -> LimpezaController : POST /limpeza/{id}/limpo
LimpezaController -> ILimpezaService : marcarComoLimpo(id)
ILimpezaService -> AlojamentoRepository : findById(id)

alt alojamento inexistente
  AlojamentoRepository --> ILimpezaService : vazio
  ILimpezaService --> LimpezaController : false
  LimpezaController --> ResponsavelLimpeza : mostrar erro
else alojamento encontrado
  AlojamentoRepository --> ILimpezaService : Alojamento
  ILimpezaService -> AlojamentoRepository : save(estado CONCLUIDO)
  ILimpezaService -> AuditoriaOperacaoService : registarSucesso(LIMPEZA_REALIZADA)
  ILimpezaService --> LimpezaController : true
  LimpezaController --> ResponsavelLimpeza : confirmar limpeza
end

@enduml
