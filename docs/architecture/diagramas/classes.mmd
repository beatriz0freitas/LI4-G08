---
title: Diagrama de Classes
description: Modelo de domínio completo do sistema de gestão de hotel para animais.
---
classDiagram
    direction TB

    class Utilizador {
        <<Abstract>>
        +Long id
        +Boolean ativo
        +DateTime criadoEm
        +DateTime atualizadoEm
    }

    class Tutor {
        +String nome
        +String nif
        +String email
        +String contacto
        +String endereco
    }
    Utilizador <|-- Tutor

    class Colaborador {
        +String nome
        +String email
        +String contacto
        +PerfilAcesso perfilAcesso
        +temPermissao(operacao) Boolean
    }
    Utilizador <|-- Colaborador

    class Animal {
        +Long id
        +String nome
        +Especie especie
        +String raca
        +Date dataNascimento
        +Double peso
        +String estadoSaude
        +String necessidadesAlimentares
        +String medicacaoEmCurso
        +String necessidadesEspeciais
    }
    Tutor "1" o-- "0..*" Animal : possui

    class Alojamento {
        +Long id
        +TipoAlojamento tipo
        +Especie especieSuportada
        +EstadoLimpeza estadoLimpeza
        +String numero
        +Integer capacidade
        +Double precoDiario
        +estaDisponivel(dataInicio, dataFim) Boolean
        +estaDisponivel() Boolean
        +suportaEspecie(especie) Boolean
        +podeSerReservado() Boolean
    }

    class Reserva {
        +Long id
        +String codigo
        +Date dataInicio
        +Date dataFim
        +EstadoReserva estado
        +DateTime criadaEm
        +DateTime atualizadaEm
        +podeIniciarEstadia() Boolean
        +estaCancelada() Boolean
        +estaVencida() Boolean
    }
    Tutor "1" -- "0..*" Reserva : efetua
    Animal "1" -- "0..*" Reserva : reservadoEm
    Alojamento "1" -- "0..*" Reserva : aloca

    class Estadia {
        +Long id
        +String codigo
        +DateTime dataCheckIn
        +DateTime dataCheckOut
        +EstadoEstadia estado
        +DateTime criadaEm
        +DateTime encerradaEm
        +foiEncerrada() Boolean
        +temPagamentoPendente() Boolean
    }
    Estadia -- "1" Reserva
    Estadia -- "1" Animal
    Estadia -- "1" Alojamento
    Estadia -- "1" Colaborador : criadoPor
    Estadia -- "1" Colaborador : atualizadoPor

    class Cuidado {
        +Long id
        +TipoCuidado tipo
        +String descricao
        +DateTime dataHora
        +DateTime criadoEm
        +pertenceAoMesmoTurno(outroCuidado) Boolean
    }
    Estadia "1" *-- "0..*" Cuidado
    Cuidado -- "1" Colaborador : realizadoPor

    class Nota {
        +Long id
        +String descricao
        +DateTime dataHora
        +Turno turno
        +DateTime criadoEm
    }
    Estadia "1" *-- "0..*" Nota
    Nota -- "1" Colaborador : criadaPor

    class ServicoExtra {
        +Long id
        +TipoServicoExtra tipo
        +String descricao
        +Double custo
        +DateTime data
        +DateTime criadoEm
        +podeSerAlterado() Boolean
    }
    Estadia "1" *-- "0..*" ServicoExtra
    ServicoExtra -- "1" Colaborador : registadoPor

    class Fatura {
        +Long id
        +String numero
        +DateTime dataEmissao
        +Double valorBase
        +Double desconto
        +Double total
        +EstadoFatura estado
        +String observacoes
        +DateTime criadaEm
        +estaQuitada() Boolean
        +temSaldoPendente() Double
        +podeSerAlterada() Boolean
    }
    Estadia "1" -- "1" Fatura

    class Pagamento {
        +Long id
        +Double valor
        +MetodoPagamento metodo
        +EstadoPagamento estado
        +Date dataVencimento
        +DateTime dataPagamento
        +String motivo
        +DateTime criadoEm
    }
    Fatura "1" *-- "0..*" Pagamento

    class HistorialClinico {
        +Long id
    }
    Animal "1" *-- "1" HistorialClinico

    class IntervencaoClinica {
        +Long id
        +DateTime dataHora
        +String descricao
        +Double custo
        +DateTime criadoEm
    }
    HistorialClinico "1" *-- "0..*" IntervencaoClinica
    IntervencaoClinica -- "1" Colaborador : realizadoPor
    IntervencaoClinica "0..1" -- "0..1" ServicoExtra : servicoExtraAssociado

    class Prescricao {
        +Long id
        +String descricao
        +Date dataInicio
        +Date dataFim
    }
    IntervencaoClinica "1" *-- "0..*" Prescricao

    class AplicacaoPrescricao {
        +Long id
        +DateTime dataHora
        +String observacoes
    }
    Prescricao "1" *-- "0..*" AplicacaoPrescricao
    AplicacaoPrescricao -- "1" Colaborador : aplicadoPor

    class RegistoLimpeza {
        +Long id
        +DateTime dataHora
        +String observacoes
    }
    Alojamento "1" *-- "0..*" RegistoLimpeza
    RegistoLimpeza -- "1" Colaborador : efetuadoPor

    class ItemPlanoCuidado {
        +String tipo
        +String periodicidade
        +String observacoes
    }
    Estadia "1" *-- "0..*" ItemPlanoCuidado : cuidadosPlaneados

      %% Enums
    class PerfilAcesso {
        <<enumeration>>
        Diretor
        Rececionista
        Cuidador
        Veterinario
        ResponsavelLimpeza
    }

    class Especie {
        <<enumeration>>
        Cao
        Gato
    }

    class TipoAlojamento {
        <<enumeration>>
        Canino
        Felino
    }

    class EstadoLimpeza {
        <<enumeration>>
        Pendente
        EmLimpeza
        Concluido
    }

    class EstadoReserva {
        <<enumeration>>
        Confirmada
        Cancelada
    }

    class EstadoEstadia {
        <<enumeration>>
        EmCurso
        Encerrada
    }

    class EstadoFatura {
        <<enumeration>>
        Emitida
        Paga
        ParcialPendente
    }

    class MetodoPagamento {
        <<enumeration>>
        Numerario
        Cartao
        MBWay
        Transferencia
    }

    class EstadoPagamento {
        <<enumeration>>
        Liquidado
        Pendente
    }

    class TipoCuidado {
        <<enumeration>>
        Alimentacao
        Medicacao
        Higiene
        Atividade
        Observacao
    }

    class TipoServicoExtra {
        <<enumeration>>
        Banho
        Passeio
        Tosquia
        MedicacaoPrescrita
        Outro
    }

    class Turno {
        <<enumeration>>
        Matutino
        Vespertino
        Noturno
    }

    class ReservaService {
        +criarReserva(tutor, animal, alojamento, dataInicio, dataFim) Reserva
        +confirmarReserva(reserva) void
        +cancelarReserva(reserva) void
        +consultarDisponibilidade(alojamento, dataInicio, dataFim, especie) Boolean
    }
    ReservaService ..> ReservaRepository
    ReservaService ..> AlojamentoRepository

    class EstadiaService {
        +iniciarEstadia(reserva, colaborador) Estadia
        +encerrarEstadia(estadia, colaborador) void
    }
    EstadiaService ..> EstadiaRepository
    EstadiaService ..> FaturacaoService
    EstadiaService ..> ReservaRepository

    class AlojamentoService {
        +verificarDisponibilidade(alojamento, dataInicio, dataFim) Boolean
        +atualizarEstadoLimpeza(alojamento, novoEstado) void
    }
    AlojamentoService ..> AlojamentoRepository

    class FaturacaoService {
        +gerarFatura(estadia) Fatura
        +registarPagamento(fatura, pagamento) void
    }
    FaturacaoService ..> FaturaRepository
    FaturacaoService ..> EstadiaRepository
    FaturacaoService ..> PagamentoRepository

    class ServicoExtraService {
        +registarServicoExtra(estadia, tipo, descricao, custo, colaborador) ServicoExtra
        +alterarServicoExtra(servicoExtra, dados) void
    }
    ServicoExtraService ..> ServicoExtraRepository
    ServicoExtraService ..> EstadiaRepository

    class NotaService {
        +registarNota(estadia, turno, descricao, colaborador) Nota
        +listarNotasPorEstadia(estadia) Collection~Nota~
    }
    NotaService ..> NotaRepository
    NotaService ..> EstadiaRepository

    class ClinicaService {
        +registarIntervencao(animal, colaborador, descricao, custo) IntervencaoClinica
        +criarPrescricao(intervencao, descricao, dataInicio, dataFim) Prescricao
        +registarAplicacao(prescricao, colaborador, observacoes) AplicacaoPrescricao
    }
    ClinicaService ..> IntervencaoClinicaRepository
    ClinicaService ..> PrescricaoRepository
    ClinicaService ..> AplicacaoPrescricaoRepository
    ClinicaService ..> AnimalRepository
    ClinicaService ..> HistorialClinicoRepository

    class LimpezaService {
        +registarLimpeza(alojamento, colaborador, observacoes) RegistoLimpeza
        +atualizarEstadoAlojamento(alojamento, novoEstado) void
    }
    LimpezaService ..> RegistoLimpezaRepository
    LimpezaService ..> AlojamentoRepository

    class AnimalService {
        +criarAnimal(tutor, nome, especie, raca, dataNascimento) Animal
        +consultarHistorialClinico(animal) HistorialClinico
    }
    AnimalService ..> AnimalRepository
    AnimalService ..> TutorRepository

    class UtilizadorService {
        +autenticar(username, password) Utilizador
        +criarColaborador(dados, perfil) Colaborador
    }
    UtilizadorService ..> UtilizadorRepository

    class CuidadoService {
        +registarCuidado(estadia, cuidado) void
    }
    CuidadoService ..> CuidadoRepository
    CuidadoService ..> EstadiaRepository

    class Relatorio {
        +Date inicio
        +Date fim
        +String tipo
        +String conteudo
    }

    class RelatorioService {
        +emitirOcupacao(inicio, fim) Relatorio
        +emitirFaturacao(inicio, fim) Relatorio
        +emitirCuidados(inicio, fim) Relatorio
    }
    RelatorioService ..> EstadiaRepository
    RelatorioService ..> FaturaRepository
    RelatorioService ..> CuidadoRepository

    class ReservaRepository { <<Repository>> }
    class EstadiaRepository { <<Repository>> }
    class AlojamentoRepository { <<Repository>> }
    class FaturaRepository { <<Repository>> }
    class PagamentoRepository { <<Repository>> }
    class AnimalRepository { <<Repository>> }
    class UtilizadorRepository { <<Repository>> }
    class CuidadoRepository { <<Repository>> }
    class TutorRepository { <<Repository>> }
    class ServicoExtraRepository { <<Repository>> }
    class NotaRepository { <<Repository>> }
    class IntervencaoClinicaRepository { <<Repository>> }
    class PrescricaoRepository { <<Repository>> }
    class AplicacaoPrescricaoRepository { <<Repository>> }
    class RegistoLimpezaRepository { <<Repository>> }
    class HistorialClinicoRepository { <<Repository>> }

    %% Mapeamento explícito Repository -> Entidade
    ReservaRepository ..> Reserva
    EstadiaRepository ..> Estadia
    AlojamentoRepository ..> Alojamento
    FaturaRepository ..> Fatura
    PagamentoRepository ..> Pagamento
    AnimalRepository ..> Animal
    UtilizadorRepository ..> Utilizador
    CuidadoRepository ..> Cuidado
    TutorRepository ..> Tutor
    ServicoExtraRepository ..> ServicoExtra
    NotaRepository ..> Nota
    IntervencaoClinicaRepository ..> IntervencaoClinica
    PrescricaoRepository ..> Prescricao
    AplicacaoPrescricaoRepository ..> AplicacaoPrescricao
    RegistoLimpezaRepository ..> RegistoLimpeza
    HistorialClinicoRepository ..> HistorialClinico
