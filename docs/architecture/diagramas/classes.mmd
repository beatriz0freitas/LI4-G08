classDiagram
direction TB

%% dominio
namespace dominio {
class Tutor {
  +UUID id
  +String nome
  +String nif
  +String email
  +String contacto
  +String endereco
}

class Colaborador {
  +UUID id
  +String nome
  +String email
  +String contacto
  +PerfilAcesso perfilAcesso
}

class Animal {
  +UUID id
  +String nome
  +String especie
  +String raca
  +EstadoSaude estadoSaude
  +String necessidadesEspeciais
}

class HistorialClinico {
  +UUID id
  +IntervencaoClinica getUltimaIntervencao()
  +boolean temPrescricaoAtiva()
}

class IntervencaoClinica {
  +UUID id
  +DateTime dataHora
  +String descricao
  +Decimal custo
}

class Alojamento {
  +UUID id
  +String tipoAlojamento
  +EstadoLimpeza estadoLimpeza
  +Integer capacidade
  +Decimal precoDiario
}

class Reserva {
  +UUID id
  +String codigo
  +Date dataInicio
  +Date dataFim
  +EstadoReserva estadoReserva
  +Colaborador criadaPor
}

class Estadia {
  +UUID id
  +String codigo
  +DateTime dataCheckIn
  +DateTime dataCheckOut
  +String estadoEstadia
}

class Cuidado {
  +UUID id
  +TipoCuidado tipoCuidado
  +String descricao
  +DateTime dataHora
  +Colaborador realizadoPor
}

class Nota {
  +UUID id
  +String descricao
  +DateTime dataHora
  +Colaborador criadaPor
}

class ServicoExtra {
  +UUID id
  +TipoServicoExtra tipoServicoExtra
  +String descricao
  +Decimal custo
  +Colaborador registadoPor
  +Date data
}

class Fatura {
  +UUID id
  +String numero
  +Date dataEmissao
  +Decimal valorBase
  +Decimal desconto
  +Decimal total
  +EstadoFatura estadoFatura
}

class Pagamento {
  +UUID id
  +Decimal valor
  +MetodoPagamento metodoPagamento
  +EstadoPagamento estadoPagamento
  +DateTime dataPagamento
  +Date dataVencimento
}

}

