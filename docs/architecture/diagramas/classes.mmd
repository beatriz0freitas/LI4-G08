---
title: Diagrama de Classes
description: Modelo de domínio completo do sistema de gestão de hotel para animais.
---
classDiagram
    direction LR

    class Utilizador {
        <<Abstract>>
        +Long id
        +Boolean ativo
        +DateTime criadoEm
        +DateTime atualizadoEm
    }

    class Tutor {
        +String nome
        +String nif
        +String email
        +String contacto
        +String endereco
        +possuiAnimais() Collection~Animal~
    }
    Utilizador <|-- Tutor

    class Colaborador {
        +String nome
        +String email
        +String contacto
        +PerfilAcesso perfilAcesso
        +temPermissao(operacao) Boolean
    }
    Utilizador <|-- Colaborador

    class Animal {
        +Long id
        +String nome
        +Especie especie
        +String raca
        +Date dataNascimento
        +Double peso
        +String estadoSaude
        +String necessidadesAlimentares
        +String medicacaoEmCurso
        +String necessidadesEspeciais
    }
    Tutor "1" -- "0..*" Animal : possui

    class Alojamento {
        +Long id
        +TipoAlojamento tipo
        +Especie especieSuportada
        +EstadoLimpeza estadoLimpeza
        +String numero
        +Integer capacidade
        +Double precoDiario
        +estaDisponivel(dataInicio, dataFim) Boolean
        +estaDisponivel() Boolean
        +suportaEspecie(especie) Boolean
        +podeSerReservado() Boolean
    }

    class Reserva {
        +Long id
        +String codigo
        +Date dataInicio
        +Date dataFim
        +EstadoReserva estado
        +DateTime criadaEm
        +DateTime atualizadaEm
        +podeIniciarEstadia() Boolean
        +estaCancelada() Boolean
        +estaVencida() Boolean
    }
    Reserva "1" -- "1" Tutor
    Reserva "1" -- "1" Animal
    Reserva "1" -- "1" Alojamento

    class Estadia {
        +Long id
        +String codigo
        +DateTime dataCheckIn
        +DateTime dataCheckOut
        +EstadoEstadia estado
        +DateTime criadaEm
        +DateTime encerradaEm
        +foiEncerrada() Boolean
        +temPagamentoPendente() Boolean
    }
    Estadia "1" -- "1" Reserva
    Estadia "1" -- "1" Animal
    Estadia "1" -- "1" Alojamento
    Estadia "1" -- "1" Colaborador : criadoPor
    Estadia "1" -- "1" Colaborador : atualizadoPor

    class Cuidado {
        +Long id
        +TipoCuidado tipo
        +String descricao
        +DateTime dataHora
        +DateTime criadoEm
        +pertenceAoMesmoTurno(outroCuidado) Boolean
    }
    Estadia "1" -- "0..*" Cuidado
    Cuidado "1" -- "1" Colaborador : realizadoPor

    class Nota {
        +Long id
        +String descricao
        +DateTime dataHora
        +Turno turno
        +DateTime criadaEm
    }
    Estadia "1" -- "0..*" Nota
    Nota "1" -- "1" Colaborador : criadaPor

    class ServicoExtra {
        +Long id
        +TipoServicoExtra tipo
        +String descricao
        +Double custo
        +DateTime data
        +DateTime criadoEm
        +podeSerAlterado() Boolean
    }
    Estadia "1" -- "0..*" ServicoExtra
    ServicoExtra "1" -- "1" Colaborador : registadoPor

    class Fatura {
        +Long id
        +String numero
        +DateTime dataEmissao
        +Double valorBase
        +Double desconto
        +Double total
        +EstadoFatura estado
        +String observacoes
        +DateTime criadaEm
        +estaQuitada() Boolean
        +temSaldoPendente() Double
        +podeSerAlterada() Boolean
    }
    Estadia "1" -- "1" Fatura

    class Pagamento {
        +Long id
        +Double valor
        +MetodoPagamento metodo
        +EstadoPagamento estado
        +Date dataVencimento
        +DateTime dataPagamento
        +String motivo
        +DateTime criadoEm
    }
    Fatura "1" -- "0..*" Pagamento

    class HistorialClinico {
        +Long id
    }
    Animal "1" -- "1" HistorialClinico

    class IntervencaoClinica {
        +Long id
        +DateTime dataHora
        +String descricao
        +Double custo
        +DateTime criadoEm
    }
    HistorialClinico "1" -- "0..*" IntervencaoClinica
    IntervencaoClinica "1" -- "1" Colaborador : realizadoPor
    IntervencaoClinica "0..1" -- "0..1" ServicoExtra : servicoExtraAssociado

    class Prescricao {
        +Long id
        +String descricao
        +Date dataInicio
        +Date dataFim
    }
    IntervencaoClinica "1" -- "0..*" Prescricao

    class AplicacaoPrescricao {
        +Long id
        +DateTime dataHora
        +String observacoes
    }
    Prescricao "1" -- "0..*" AplicacaoPrescricao
    AplicacaoPrescricao "1" -- "1" Colaborador : aplicadoPor

    class EventoAuditoria {
        +Long id
        +TipoEvento tipoEvento
        +String entidadeAfetada
        +Long idEntidade
        +String alteracoes
        +DateTime dataHora
        +String ipOrigem
        +String detalhes
    }
    EventoAuditoria "1" -- "1" Colaborador : utilizador

    class RegistoLimpeza {
        +Long id
        +DateTime dataHora
        +String observacoes
    }
    Alojamento "1" -- "0..*" RegistoLimpeza
    RegistoLimpeza "1" -- "1" Colaborador : efetuadoPor

    class ItemPlanoCuidado {
        +String tipo
        +String periodicidade
        +String observacoes
    }
    Estadia "1" -- "0..*" ItemPlanoCuidado : cuidadosPlaneados

    %% Enums
    class PerfilAcesso {
        <<enumeration>>
        Diretor
        Rececionista
        Cuidador
        Veterinario
        ResponsavelLimpeza
    }

    class Especie {
        <<enumeration>>
        Cao
        Gato
    }

    class TipoAlojamento {
        <<enumeration>>
        Canino
        Felino
    }

    class EstadoLimpeza {
        <<enumeration>>
        Pendente
        EmLimpeza
        Concluido
    }

    class EstadoReserva {
        <<enumeration>>
        Confirmada
        Cancelada
    }

    class EstadoEstadia {
        <<enumeration>>
        EmCurso
        Encerrada
    }

    class EstadoFatura {
        <<enumeration>>
        Emitida
        Paga
        ParcialmPendente
    }

    class MetodoPagamento {
        <<enumeration>>
        Numerario
        Cartao
        MBWay
        Transferencia
    }

    class EstadoPagamento {
        <<enumeration>>
        Liquidado
        Pendente
    }

    class TipoCuidado {
        <<enumeration>>
        Alimentacao
        Medicacao
        Higiene
        Atividade
        Observacao
    }

    class TipoServicoExtra {
        <<enumeration>>
        Banho
        Passeio
        Tosquia
        MedicacaoPrescrita
        Outro
    }

    class TipoEvento {
        <<enumeration>>
        CRIACAO
        ATUALIZACAO
        DELECAO
        CHECK_IN
        CHECK_OUT
        PAGAMENTO_REGISTADO
        SERVICO_EXTRA_REGISTADO
        LIMPEZA_CONCLUIDA
    }

    class Turno {
        <<enumeration>>
        Matutino
        Vespertino
        Noturno
    }

    %% Camadas de Serviço e Repositório (representação simplificada)
    class ReservaService {
        +criarReserva(tutor, animal, alojamento, dataInicio, dataFim) Reserva
        +confirmarReserva(reserva) void
        +cancelarReserva(reserva) void
        +consultarDisponibilidade(alojamento, dataInicio, dataFim, especie) Boolean
    }
    ReservaService ..> ReservaRepository

    class EstadiaService {
        +iniciarEstadia(reserva, colaborador) Estadia
        +encerrarEstadia(estadia, colaborador) void
    }
    EstadiaService ..> EstadiaRepository
    EstadiaService ..> FaturacaoService

    class AlojamentoService {
        +verificarDisponibilidade(alojamento, dataInicio, dataFim) Boolean
        +atualizarEstadoLimpeza(alojamento, novoEstado) void
    }
    AlojamentoService ..> AlojamentoRepository

    class FaturacaoService {
        +gerarFatura(estadia) Fatura
        +registarPagamento(fatura, pagamento) void
    }
    FaturacaoService ..> FaturaRepository
    FaturacaoService ..> PagamentoRepository

    class AnimalService {
        +criarAnimal(tutor, dados) Animal
        +consultarHistorialClinico(animal) HistorialClinico
    }
    AnimalService ..> AnimalRepository

    class UtilizadorService {
        +autenticar(username, password) Utilizador
        +criarColaborador(dados, perfil) Colaborador
    }
    UtilizadorService ..> UtilizadorRepository

    class CuidadoService
    class RelatorioService

    class ReservaRepository {
        <<Repository>>
    }
    class EstadiaRepository {
        <<Repository>>
    }
    class AlojamentoRepository {
        <<Repository>>
    }
    class FaturaRepository {
        <<Repository>>
    }
    class PagamentoRepository {
        <<Repository>>
    }
    class AnimalRepository {
        <<Repository>>
    }
    class UtilizadorRepository {
        <<Repository>>
    }
    class CuidadoRepository {
        <<Repository>>
    }
    class TutorRepository {
        <<Repository>>
    }
