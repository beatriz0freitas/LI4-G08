@startuml

top to bottom direction

namespace dominio {
class Tutor {
  +UUID id
  +String nome
  +String nif
  +String email
  +String contacto
  +String endereco
}

class Colaborador {
  +UUID id
  +String nome
  +String email
  +String contacto
  +PerfilAcesso perfilAcesso
}

class Animal {
  +UUID id
  +String nome
  +String especie
  +String raca
  +EstadoSaude estadoSaude
  +String necessidadesEspeciais
}

class HistorialClinico {
  +UUID id
  +IntervencaoClinica getUltimaIntervencao()
  +boolean temPrescricaoAtiva()
}

class IntervencaoClinica {
  +UUID id
  +DateTime dataHora
  +String descricao
  +Decimal custo
}

class Alojamento {
  +UUID id
  +String tipoAlojamento
  +EstadoLimpeza estadoLimpeza
  +Integer capacidade
  +Decimal precoDiario
}

class Reserva {
  +UUID id
  +String codigo
  +Date dataInicio
  +Date dataFim
  +EstadoReserva estadoReserva
  +Colaborador criadaPor
}

class Estadia {
  +UUID id
  +String codigo
  +DateTime dataCheckIn
  +DateTime dataCheckOut
  +String estadoEstadia
}

class Cuidado {
  +UUID id
  +TipoCuidado tipoCuidado
  +String descricao
  +DateTime dataHora
  +Colaborador realizadoPor
}

class Nota {
  +UUID id
  +String descricao
  +DateTime dataHora
  +Colaborador criadaPor
}

class ServicoExtra {
  +UUID id
  +TipoServicoExtra tipoServicoExtra
  +String descricao
  +Decimal custo
  +Colaborador registadoPor
  +Date data
}

class Fatura {
  +UUID id
  +String numero
  +Date dataEmissao
  +Decimal valorBase
  +Decimal desconto
  +Decimal total
  +EstadoFatura estadoFatura
}

class Pagamento {
  +UUID id
  +Decimal valor
  +MetodoPagamento metodoPagamento
  +EstadoPagamento estadoPagamento
  +DateTime dataPagamento
  +Date dataVencimento
}
}

namespace fachada {
class GestHotelFacade {
  +autenticar()
  +consultarDisponibilidade()
  +registarReserva()
  +registarCheckIn()
  +registarCheckOut()
  +gerirFaturacao()
  +gerirClinica()
  +gerarRelatorios()
}
}

namespace servico {
interface UtilizadorService {
  +autenticar(email: String, palavraPasse: String)
  +registarTutor(tutor: Tutor)
}

class UtilizadorServiceImpl {
  +autenticar(email: String, palavraPasse: String)
  +registarTutor(tutor: Tutor)
}

interface AnimalService {
  +registarAnimal(animal: Animal)
  +atualizarEstadoSaude(animal: Animal, estado: EstadoSaude)
}

class AnimalServiceImpl {
  +registarAnimal(animal: Animal)
  +atualizarEstadoSaude(animal: Animal, estado: EstadoSaude)
}

interface ClinicaService {
  +registarIntervencaoClinica(animal: Animal, intervencao: IntervencaoClinica)
  +consultarHistorial(animal: Animal)
}

class ClinicaServiceImpl {
  +registarIntervencaoClinica(animal: Animal, intervencao: IntervencaoClinica)
  +consultarHistorial(animal: Animal)
}

interface AlojamentoService {
  +consultarDisponibilidade(inicio: Date, fim: Date, especie: String)
  +registarLimpeza(alojamento: Alojamento)
}

class AlojamentoServiceImpl {
  +consultarDisponibilidade(inicio: Date, fim: Date, especie: String)
  +registarLimpeza(alojamento: Alojamento)
}

interface ReservaService {
  +criarReserva()
  +cancelarReserva()
}

class ReservaServiceImpl {
  +criarReserva()
  +cancelarReserva()
}

interface EstadiaService {
  +registarCheckIn()
  +registarCheckOut()
  +registarCuidadoDiario()
  +registarServicoExtra()
}

class EstadiaServiceImpl {
  +registarCheckIn()
  +registarCheckOut()
  +registarCuidadoDiario()
  +registarServicoExtra()
}

interface FaturacaoService {
  +emitirFatura()
  +recalcularFatura()
}

class FaturacaoServiceImpl {
  +emitirFatura()
  +recalcularFatura()
}

interface PagamentoService {
  +registarPagamento()
  +validarPagamento()
}

class PagamentoServiceImpl {
  +registarPagamento()
  +validarPagamento()
}

interface RelatorioService {
  +gerarDashboard()
  +gerarRelatorios()
}

class RelatorioServiceImpl {
  +gerarDashboard()
  +gerarRelatorios()
}
}

namespace repositorio {
interface AlojamentoRepository {
  +findDisponiveis(inicio, fim, especie)
  +findByEstadoLimpeza(estado)
  +save(alojamento)
}

class AlojamentoRepositoryImpl {
  +findDisponiveis(inicio, fim, especie)
  +findByEstadoLimpeza(estado)
  +save(alojamento)
}

interface ReservaRepository {
  +findByAlojamentoAndPeriodo(alojamento, inicio, fim)
  +findByAnimal(animal)
  +findByEstado(estado)
  +save(reserva)
}

class ReservaRepositoryImpl {
  +findByAlojamentoAndPeriodo(alojamento, inicio, fim)
  +findByAnimal(animal)
  +findByEstado(estado)
  +save(reserva)
}

interface EstadiaRepository {
  +findEmCurso()
  +findByAnimal(animal)
  +findByPeriodo(inicio, fim)
  +save(estadia)
}

class EstadiaRepositoryImpl {
  +findEmCurso()
  +findByAnimal(animal)
  +findByPeriodo(inicio, fim)
  +save(estadia)
}

interface FaturaRepository {
  +findPendentes()
  +findByPeriodo(inicio, fim)
  +save(fatura)
}

class FaturaRepositoryImpl {
  +findPendentes()
  +findByPeriodo(inicio, fim)
  +save(fatura)
}

interface PagamentoRepository {
  +findByEstado(estado)
  +findByFatura(fatura)
  +save(pagamento)
}

class PagamentoRepositoryImpl {
  +findByEstado(estado)
  +findByFatura(fatura)
  +save(pagamento)
}

interface AnimalRepository {
  +findByTutor(tutor)
  +save(animal)
}

class AnimalRepositoryImpl {
  +findByTutor(tutor)
  +save(animal)
}

interface HistorialClinicoRepository {
  +findByAnimal(animal)
  +save(historial)
}

class HistorialClinicoRepositoryImpl {
  +findByAnimal(animal)
  +save(historial)
}
}

namespace fabrica {
class FaturaFactory {
  +criar(estadia, estrategia)
}
}

namespace estrategia {
interface EstrategiaCalculoFatura {
  +calcular(estadia)
}

class CalculoStandard {
  +calcular(estadia)
}

interface AlojamentoStateListener {
  +estadoAlterado(alojamento)
}
}

namespace excecao {
class ReservaNaoConfirmadaException
class AlojamentoIndisponivelException
class PagamentoPendenteException
class AnimalEmEstadiaException
}

namespace enumeracoes {
enum EstadoSaude {
  Estavel
  EmObservacao
  Critico
}

enum EstadoReserva {
  Pendente
  Confirmada
  Cancelada
}

enum MetodoPagamento {
  Numerario
  Cartao
  MBWay
  Transferencia
  MBReference
}

enum TipoCuidado {
  Alimentacao
  Higiene
  Passeio
  Medicao
}

enum TipoServicoExtra {
  MedicacaoPrescrita
  BanhoExtra
  Tosquia
  Transporte
}

enum EstadoLimpeza {
  Concluido
  PendenteLimpeza
  Ocupado
}

enum EstadoFatura {
  Emitida
  ParcialPendente
  Paga
}

enum EstadoPagamento {
  Pendente
  Liquidado
}

enum PerfilAcesso {
  Admin
  Colaborador
  Veterinario
  Tutor
}
}

GestHotelFacade --> UtilizadorService : autentica/regista
GestHotelFacade --> AnimalService : coordena
GestHotelFacade --> ClinicaService : coordena
GestHotelFacade --> AlojamentoService : coordena
GestHotelFacade --> ReservaService : coordena
GestHotelFacade --> EstadiaService : coordena
GestHotelFacade --> FaturacaoService : coordena
GestHotelFacade --> PagamentoService : coordena
GestHotelFacade --> RelatorioService : coordena

UtilizadorService ..> AnimalService : suporta onboarding
ReservaService ..> UtilizadorService : valida tutor
ReservaService ..> AnimalService : valida animal
ReservaService ..> AlojamentoService : valida disponibilidade
EstadiaService ..> ReservaService : confirma reserva
EstadiaService ..> AnimalService : atualiza estado
EstadiaService ..> AlojamentoService : liberta/ocupa alojamento
FaturacaoService ..> EstadiaService : consome estadia
FaturacaoService ..> FaturaFactory : cria fatura
FaturacaoService ..> EstrategiaCalculoFatura : calcula custos
PagamentoService ..> FaturacaoService : associa fatura
RelatorioService ..> FaturacaoService : recolhe indicadores
RelatorioService ..> EstadiaService : recolhe estadias
ClinicaService ..> AnimalService : consulta animal
ClinicaService ..> EstadiaService : referencia estadia
AlojamentoService ..> AlojamentoStateListener : notifica limpeza

UtilizadorService ..> AnimalRepository : consulta/regista
AnimalService ..> AnimalRepository : persiste animal
AnimalService ..> HistorialClinicoRepository : atualiza historial
ClinicaService ..> HistorialClinicoRepository : regista intervencao
AlojamentoService ..> AlojamentoRepository : consulta disponibilidade
AlojamentoService ..> AlojamentoRepository : altera limpeza
ReservaService ..> ReservaRepository : cria/cancela reserva
EstadiaService ..> EstadiaRepository : cria/fecha estadia
EstadiaService ..> ReservaRepository : valida reserva
FaturacaoService ..> EstadiaRepository : calcula base
FaturacaoService ..> FaturaRepository : emite fatura
PagamentoService ..> FaturaRepository : associa fatura
PagamentoService ..> PagamentoRepository : regista pagamento
RelatorioService ..> FaturaRepository : consulta faturacao
RelatorioService ..> EstadiaRepository : consulta estadias
RelatorioService ..> ReservaRepository : consulta reservas

Animal --> EstadoSaude : estadoSaude
Reserva --> EstadoReserva : estadoReserva
Alojamento --> EstadoLimpeza : estadoLimpeza
Cuidado --> TipoCuidado : tipoCuidado
ServicoExtra --> TipoServicoExtra : tipoServicoExtra
Fatura --> EstadoFatura : estadoFatura
Pagamento --> EstadoPagamento : estadoPagamento
Pagamento --> MetodoPagamento : metodoPagamento
Colaborador --> PerfilAcesso : perfilAcesso

Tutor "1" --> "0..*" Animal : possui
Tutor "1" --> "0..*" Reserva : referencia operacional
Colaborador "1" --> "0..*" Reserva : cria
Colaborador "1" --> "0..*" Estadia : executa
Animal "1" --> "1" HistorialClinico : tem
HistorialClinico "1" --> "0..*" IntervencaoClinica : agrega
Alojamento "1" --> "0..*" Reserva : suporta
Alojamento "1" --> "0..*" Estadia : suporta
Reserva "0..1" --> "1" Estadia : origina
Estadia "1" --> "1" Reserva : base
Estadia "*" --> "1" Tutor : rastreia
Estadia "*" --> "1" Animal : inclui
Estadia "*" --> "1" Alojamento : ocupa
Estadia "1" --> "1" Fatura : gera
Estadia "1" --> "0..*" Cuidado : regista
Estadia "1" --> "0..*" Nota : inclui
Estadia "1" --> "0..*" ServicoExtra : adiciona
Fatura "*" --> "1" Tutor : pertence
Fatura "1" --> "1..*" Pagamento : recebe
IntervencaoClinica "0..1" --> "0..1" ServicoExtra : associacao opcional

UtilizadorService <|.. UtilizadorServiceImpl
AnimalService <|.. AnimalServiceImpl
ClinicaService <|.. ClinicaServiceImpl
AlojamentoService <|.. AlojamentoServiceImpl
ReservaService <|.. ReservaServiceImpl
EstadiaService <|.. EstadiaServiceImpl
FaturacaoService <|.. FaturacaoServiceImpl
PagamentoService <|.. PagamentoServiceImpl
RelatorioService <|.. RelatorioServiceImpl

AlojamentoRepository <|.. AlojamentoRepositoryImpl
ReservaRepository <|.. ReservaRepositoryImpl
EstadiaRepository <|.. EstadiaRepositoryImpl
FaturaRepository <|.. FaturaRepositoryImpl
PagamentoRepository <|.. PagamentoRepositoryImpl
AnimalRepository <|.. AnimalRepositoryImpl
HistorialClinicoRepository <|.. HistorialClinicoRepositoryImpl

EstrategiaCalculoFatura <|.. CalculoStandard
FaturaFactory ..> EstrategiaCalculoFatura : usa
AlojamentoStateListener ..> Alojamento : observa

UtilizadorService ..> ReservaNaoConfirmadaException
ReservaService ..> AlojamentoIndisponivelException
EstadiaService ..> PagamentoPendenteException
ClinicaService ..> AnimalEmEstadiaException

note right of Alojamento
RD-01: disponibilidade depende de periodo, especie e estado de limpeza.
end note

note right of Reserva
RD-02: uma reserva confirmada pode originar no maximo uma estadia.
end note

note right of Estadia
RD-03: uma estadia exige exatamente uma fatura.
end note

note right of Fatura
RD-04: a fatura suporta relatorio financeiro e auditoria por tutor.
end note

note right of Animal
RD-05: o estado de saude deve ser um enum fechado.
end note

note right of IntervencaoClinica
RD-06: a intervencao clinica pode originar um servico extra opcional.
end note

note right of Cuidado
RD-07: os cuidados diarios sao registados pela estadia, nao pelo controller.
end note

note right of AlojamentoStateListener
RD-08: mudancas de estado de alojamento notificam limpeza.
end note

note right of ReservaRepository
RD-09: consultas por periodo e estado sao obrigatorias para rastreabilidade.
end note

@enduml