sequenceDiagram
  autonumber
  participant Colaborador
  participant EstadiaService
  participant ReservaRepository
  participant EstadiaRepository
  participant AlojamentoStateListener

  Colaborador->>EstadiaService: registarCheckIn(reservaId)
  EstadiaService->>ReservaRepository: findByEstado(Confirmada)
  alt reserva nao confirmada
    EstadiaService-->>Colaborador: ReservaNaoConfirmadaException
  else reserva valida
    EstadiaService->>EstadiaRepository: save(estadia)
    EstadiaService->>AlojamentoStateListener: estadoAlterado(alojamento)
    AlojamentoStateListener-->>EstadiaService: estado atualizado
    EstadiaService-->>Colaborador: check-in registado
  end